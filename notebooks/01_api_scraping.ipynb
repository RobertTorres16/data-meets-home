   "source": [
    "import requests\n",
    "\n",
    "# Tus credenciales de API\n",
    "api_key = \\"TU_API_KEY\\"\n",
    "api_secret = \\"TU_API_SECRET\\"\n",
    "\n",
    "# URL de autenticación\n",
    "auth_url = \"https://api.idealista.com/oauth/token\"\n",
    "\n",
    "# Solicitar el token de acceso\n",
    "response = requests.post(auth_url, auth=(api_key, api_secret), data={'grant_type': 'client_credentials'})\n",
    "\n",
    "# Verificar si la solicitud fue exitosa\n",
    "if response.status_code == 200:\n",
    "    # Extraer el token de acceso de la respuesta\n",
    "    token = response.json()['access_token']\n",
    "    print(f\"Token de acceso obtenido: {token}\")\n",
    "else:\n",
    "    raise Exception(\"Error al obtener el token de acceso\")"
   ]
  },
